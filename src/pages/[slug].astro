---
import { getCollection, render } from "astro:content";
import LegalLayout from "../layouts/LegalLayout.astro";

// Generate /privacy and /imprint from the English legal markdown files
// in src/content/legal (German files are prefixed with "de-").
export async function getStaticPaths() {
  const entries = await getCollection("legal");
  return entries
    .filter((entry) => !entry.id.startsWith("de-"))
    .map((entry) => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<LegalLayout
  lang="en"
  title={entry.data.title}
  homeHref="/"
  backLabel="Back to Home"
  homeAriaLabel="CultureWithGen - home"
>
  <Content />
</LegalLayout>
