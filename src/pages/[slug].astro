---
import { getCollection, render } from "astro:content";
import LegalLayout from "../layouts/LegalLayout.astro";

// Generate /privacy and /imprint from the English legal markdown files
// in src/content/legal (German files are prefixed with "de-").
export async function getStaticPaths() {
  const entries = await getCollection("legal");
  return entries
    .filter((entry) => !entry.id.startsWith("de-"))
    .map((entry) => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Per-page SEO description and the German counterpart for hreflang.
const meta: Record<string, { description: string; de: string }> = {
  privacy: {
    description:
      "Privacy policy for CultureWithGen - how your data is handled when you visit the site or get in touch.",
    de: "/de/datenschutz",
  },
  imprint: {
    description:
      "Imprint and legal information for CultureWithGen intercultural communication training.",
    de: "/de/impressum",
  },
};
const m = meta[entry.id] ?? { description: entry.data.title, de: "/de/" };
---

<LegalLayout
  lang="en"
  title={entry.data.title}
  description={m.description}
  path={`/${entry.id}`}
  alternates={{ en: `/${entry.id}`, de: m.de }}
  homeHref="/"
  backLabel="Back to Home"
  homeAriaLabel="CultureWithGen - home"
>
  <Content />
</LegalLayout>
