---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allLegalDocs = await getCollection('legal');
  
  // Keep ONLY the German documents (the ones that DO start with 'de-')
  const germanDocs = allLegalDocs.filter(doc => doc.id.startsWith('de-'));

  return germanDocs.map(doc => {
    // Strip 'de-' from the URL so it becomes /de/impressum cleanly
    const cleanSlug = doc.id.replace('de-', ''); 
    return {
      params: { slug: cleanSlug }, 
      props: { doc },
    };
  });
}

const { doc } = Astro.props;
const { Content } = await render(doc);
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{doc.data.title}</title>
    <style>
      body {
        font-family: system-ui, -apple-system, sans-serif;
        line-height: 1.6;
        color: #334155;
        background-color: #f8fafc;
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem;
      }
      nav {
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid #cbd5e1;
      }
      a {
        color: #0284c7;
        text-decoration: none;
        font-weight: 600;
      }
      a:hover {
        text-decoration: underline;
      }
      h1 {
        color: #0f172a;
      }
    </style>
  </head>
  <body>
    <nav>
      <a href="/de/">← Zurück zur Startseite</a>
    </nav>
    <main>
      <h1>{doc.data.title}</h1>
      <Content />
    </main>
  </body>
</html>