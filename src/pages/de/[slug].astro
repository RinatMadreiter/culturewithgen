---
import { getCollection, render } from "astro:content";
import LegalLayout from "../../layouts/LegalLayout.astro";

// Generate /de/datenschutz and /de/impressum from the German legal markdown
// files in src/content/legal (prefixed with "de-"). The "de-" prefix is
// stripped from the URL slug.
export async function getStaticPaths() {
  const entries = await getCollection("legal");
  return entries
    .filter((entry) => entry.id.startsWith("de-"))
    .map((entry) => ({
      params: { slug: entry.id.replace(/^de-/, "") },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const slug = entry.id.replace(/^de-/, "");

// Per-page SEO description and the English counterpart for hreflang.
const meta: Record<string, { description: string; en: string }> = {
  datenschutz: {
    description:
      "Datenschutzerklärung von CultureWithGen - wie Ihre Daten beim Besuch der Website und bei der Kontaktaufnahme behandelt werden.",
    en: "/privacy",
  },
  impressum: {
    description:
      "Impressum und rechtliche Angaben zu CultureWithGen - interkulturelles Kommunikationstraining.",
    en: "/imprint",
  },
};
const m = meta[slug] ?? { description: entry.data.title, en: "/" };
---

<LegalLayout
  lang="de"
  title={entry.data.title}
  description={m.description}
  path={`/de/${slug}`}
  alternates={{ de: `/de/${slug}`, en: m.en }}
  homeHref="/de/"
  backLabel="Zurück zur Startseite"
  homeAriaLabel="CultureWithGen - Startseite"
>
  <Content />
</LegalLayout>
