---
import { getCollection, render } from "astro:content";
import LegalLayout from "../../layouts/LegalLayout.astro";

// Generate /de/datenschutz and /de/impressum from the German legal markdown
// files in src/content/legal (prefixed with "de-"). The "de-" prefix is
// stripped from the URL slug.
export async function getStaticPaths() {
  const entries = await getCollection("legal");
  return entries
    .filter((entry) => entry.id.startsWith("de-"))
    .map((entry) => ({
      params: { slug: entry.id.replace(/^de-/, "") },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<LegalLayout
  lang="de"
  title={entry.data.title}
  homeHref="/de/"
  backLabel="Zurück zur Startseite"
  homeAriaLabel="CultureWithGen - Startseite"
>
  <Content />
</LegalLayout>
