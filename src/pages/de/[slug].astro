---
import { useStoryblokApi, StoryblokComponent } from "@storyblok/astro";

// The German legal URLs use localized slugs but read the same Storyblok
// stories (field-level translation) in the "de" language dimension.
const slugMap = {
  privacy: "datenschutz",
  imprint: "impressum",
};

export async function getStaticPaths() {
  const storyblokApi = useStoryblokApi();
  const version = import.meta.env.DEV ? "draft" : "published";

  const { data } = await storyblokApi.get("cdn/stories", {
    version,
    starts_with: "legal/",
    language: "de",
  });

  return data.stories.map((story) => ({
    params: { slug: slugMap[story.slug] ?? story.slug },
    props: { story },
  }));
}

const { story } = Astro.props;
const content = story.content;
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{content.title}</title>
    <style>
      body {
        font-family: system-ui, -apple-system, sans-serif;
        line-height: 1.6;
        color: #334155;
        background-color: #f8fafc;
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem;
      }
      nav {
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid #cbd5e1;
      }
      a {
        color: #0284c7;
        text-decoration: none;
        font-weight: 600;
      }
      a:hover {
        text-decoration: underline;
      }
      .legal-prose h1 {
        color: #0f172a;
      }
    </style>
  </head>
  <body>
    <nav>
      <a href="/de/">← Zurück zur Startseite</a>
    </nav>
    <main>
      <StoryblokComponent blok={content} />
    </main>
  </body>
</html>
