---
import { getEntry } from "astro:content";
import { Image } from "astro:assets";

import "../../styles/global.css";
import "@fontsource-variable/manrope";
import "material-symbols/outlined.css";

import Navigation from "../../components/Navigation.astro";
import ObfuscatedEmail from "../../components/ObfuscatedEmail.astro";
import logo from "../../assets/logo.webp";
import Hero from "../../components/sections/Hero.astro";
import Offer from "../../components/sections/Offer.astro";
import About from "../../components/sections/About.astro";
import WhoFor from "../../components/sections/WhoFor.astro";
import Situations from "../../components/sections/Situations.astro";
import Formats from "../../components/sections/Formats.astro";
import Contact from "../../components/sections/Contact.astro";

const entry = await getEntry("landing", "de");
if (!entry) throw new Error("Missing landing content: src/content/landing/de.json");
const content = entry.data;
---

<html class="light" lang="de">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>{content.header.title}</title>
    <meta name="description" content={content.header.subtitle} />
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>

  <body
    class="bg-surface text-on-surface antialiased overflow-x-hidden font-body flex flex-col min-h-screen"
  >
    <Navigation
      homeHref="/de/"
      links={[
        { label: 'Leistungen', href: '#services' },
        { label: 'Über mich', href: '#about' },
        { label: 'Workshops', href: '#formats' },
      ]}
      ctaLabel="Beratung buchen"
    />

    <main class="pt-24 flex-1">
      <Hero {...content.header} />
      <Offer {...content.offer} />
      <About {...content.about} />
      <WhoFor {...content.whoFor} />
      <Situations {...content.situations} />
      <Formats {...content.format} />
      <Contact {...content.contact} />
    </main>

    <footer class="bg-[#1E3932] w-full border-t border-white/10 text-[#FAF9F6] font-label">
      <div class="max-w-3xl mx-auto px-6 py-12 flex flex-col items-center gap-6 text-center">

        <!-- Logo -->
        <a href="/de/" class="hover:opacity-80 transition-opacity" aria-label="CultureWithGen Startseite">
          <Image src={logo} alt="CultureWithGen" height={64} class="rounded-full" />
        </a>

        <!-- Tagline -->
        <p class="text-xs uppercase tracking-widest text-[#FAF9F6]/50 font-semibold">
          Interkulturelle Kommunikation & Skills-Training
        </p>

        <!-- Email -->
        <ObfuscatedEmail
          email={content.contact.email}
          class="text-sm text-[#FAF9F6]/80 hover:text-[#E07A5F] transition-colors tracking-wide"
        />

        <!-- Divider -->
        <div class="w-16 border-t border-white/10 mt-2"></div>

        <!-- Legal links + copyright -->
        <div class="flex flex-wrap justify-center gap-6 text-xs uppercase tracking-widest text-[#FAF9F6]/50">
          <a href="/de/datenschutz" class="hover:text-[#E07A5F] transition-colors">Datenschutz</a>
          <a href="/de/impressum" class="hover:text-[#E07A5F] transition-colors">Impressum</a>
        </div>
        <p class="text-xs text-[#FAF9F6]/30">
          © {new Date().getFullYear()} CultureWithGen
        </p>

      </div>
    </footer>
  </body>
</html>
