---
import { useStoryblokApi, StoryblokComponent } from "@storyblok/astro";

import "../styles/global.css";
import "@fontsource-variable/manrope";
import "material-symbols/outlined.css";

import Navigation from "../components/Navigation.astro";

const version = import.meta.env.DEV ? "draft" : "published";

const storyblokApi = useStoryblokApi();
const { data } = await storyblokApi.get("cdn/stories/home", {
  version,
  language: "default",
  resolve_relations: [],
});

const story = data.story;
const content = story.content;

// The footer reuses the contact details authored in the contact blok.
const contact =
  content.body?.find((b) => b.component === "contact") ?? {};
---

<html class="light" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>{content.seo_title || content.body?.[0]?.title}</title>
  </head>

  <body
    class="bg-surface text-on-surface antialiased overflow-x-hidden font-body"
  >
    <Navigation />

    <main class="pt-24">
      <StoryblokComponent blok={content} />
    </main>

    <footer
      class="bg-[#1E3932] dark:bg-[#0F1D19] w-full border-t border-white/10 text-[#FAF9F6] font-label"
    >
      <div
        class="max-w-7xl mx-auto px-12 py-16 flex flex-col md:flex-row justify-between items-center w-full"
      >
        <div class="mb-8 md:mb-0 text-center md:text-left">
          <div class="text-lg font-bold text-[#FAF9F6] mb-4">
            CultureWithGen
          </div>
          <a
            class="text-sm tracking-wide hover:text-[#E07A5F] transition-colors"
            href={`mailto:${contact.email}`}>{contact.email}</a
          >
          <p class="text-xs mt-4 text-[#FAF9F6]/60">
            {contact.location}
          </p>
        </div>
        <div class="flex flex-col items-center md:items-end space-y-4">
          <div
            class="flex flex-wrap justify-center md:justify-end gap-6 text-sm tracking-wide uppercase"
          >
            <a
              class="text-[#FAF9F6]/60 hover:text-[#E07A5F] transition-colors opacity-90 hover:opacity-100"
              href="/privacy">Privacy Policy</a
            >
            <a
              class="text-[#FAF9F6]/60 hover:text-[#E07A5F] transition-colors opacity-90 hover:opacity-100"
              href="/imprint">Imprint</a
            >
          </div>
          <p class="text-xs text-[#FAF9F6]/60 mt-6">
            © {new Date().getFullYear()} CultureWithGen. Elevating Global Perspectives.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
