---
import { getEntry } from "astro:content";
import { Image } from "astro:assets";

import "../styles/global.css";
import "@fontsource-variable/manrope";
import "material-symbols/outlined.css";

import profile1 from "../assets/profile1.webp";
import profile2 from "../assets/profile2.webp";
import profile3 from "../assets/profile3.webp";

import Navigation from "../components/Navigation.astro";

const landingData = await getEntry("landing", "en");
const content = landingData.data;/*  */
---

<html class="light" lang="en">
  <head><!--  -->
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>{content.header.title}</title>
  </head>

  <body
    class="bg-surface text-on-surface antialiased overflow-x-hidden font-body"
  >
    <Navigation />

    <main class="pt-24">
      <section
        class="relative pt-20 pb-32 px-6 lg:px-12 overflow-hidden bg-surface"
      >
        <div
          class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 items-center"
        >
          <div
            class="lg:col-span-7 z-10 flex flex-col justify-center items-start lg:pr-12"
          >
            <span
              class="inline-block px-4 py-1.5 rounded-full bg-surface-container-high text-primary text-xs font-bold uppercase tracking-widest mb-8 font-label"
            >
              Intercultural Communication & Skills Training
            </span>
            <h1
              class="text-4xl md:text-5xl lg:text-[3.5rem] leading-[1.1] font-headline font-extrabold text-primary-container tracking-[-0.02em] mb-8"
            >
              {content.header.title}
            </h1>
            <p
              class="text-xl md:text-2xl font-body font-medium text-on-surface-variant mb-6 leading-relaxed"
            >
              {content.header.subtitle}
            </p>
            <p
              class="text-base font-body text-on-surface-variant mb-12 leading-relaxed max-w-2xl"
            >
              {content.header.description}
            </p>
            <div class="flex flex-col sm:flex-row items-center gap-6">
              <a
                href="#contact"
                class="w-full sm:w-auto bg-secondary text-on-primary px-8 py-4 rounded-lg font-label font-bold tracking-wider hover:underline hover:text-secondary-fixed-dim transition-all duration-200 shadow-[0_12px_40px_rgba(30,57,50,0.06)] text-center"
              >
                Get in Touch
              </a>
            </div>
          </div>
          <div class="lg:col-span-5 relative">
            <div
              class="absolute inset-0 bg-primary-container rounded-[2rem] transform translate-x-4 translate-y-4 -z-10 opacity-10"
            >
            </div>
            <Image
              alt="Professional portrait of intercultural trainer"
              class="w-full h-auto object-cover rounded-[2rem] shadow-[0_12px_40px_rgba(30,57,50,0.06)] bg-gray-200 min-h-[400px]"
              loading="eager"
              src={profile3}
            />
          </div>
        </div>
      </section>

      <section class="py-24 px-6 lg:px-12 bg-surface-container-low" id="about">
        <div
          class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16"
        >
          <div class="w-full lg:w-5/12 flex justify-center">
            <div class="relative w-72 h-72 lg:w-96 lg:h-96">
              <Image
                alt="Trainer facilitating a workshop"
                class="w-full h-full object-cover rounded-full shadow-[0_12px_40px_rgba(30,57,50,0.06)] bg-gray-200"
                src={profile1}
              />
            </div>
          </div>
          <div class="w-full lg:w-7/12">
            <h2
              class="text-3xl lg:text-[2.75rem] font-headline font-bold text-primary-container mb-8 tracking-tight"
            >
              {content.about.title}
            </h2>

            {
              content.about.paragraphs.map((paragraph) => (
                <p class="text-lg font-body text-on-surface-variant leading-[1.6] mb-6">
                  {paragraph}
                </p>
              ))
            }

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-10">
              <div
                class="bg-surface-container-lowest p-6 rounded-xl flex items-center gap-4"
              >
                <span class="material-symbols-outlined text-secondary text-3xl"
                  >school</span
                >
                <span class="font-body font-medium text-primary-container"
                  >Degree in Psychology & Sociology</span
                >
              </div>
              <div
                class="bg-surface-container-lowest p-6 rounded-xl flex items-center gap-4"
              >
                <span class="material-symbols-outlined text-secondary text-3xl"
                  >workspace_premium</span
                >
                <span class="font-body font-medium text-primary-container"
                  >Diploma in Intercultural Competence</span
                >
              </div>
              <div
                class="bg-surface-container-lowest p-6 rounded-xl flex items-center gap-4 md:col-span-2"
              >
                <span class="material-symbols-outlined text-secondary text-3xl"
                  >public</span
                >
                <span class="font-body font-medium text-primary-container"
                  >Master’s in Adult Learning in Global Change</span
                >
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="py-24 px-6 lg:px-12 bg-surface" id="services">
        <div class="max-w-7xl mx-auto">
          <div class="mb-16">
            <h2
              class="text-3xl lg:text-[2.75rem] font-headline font-bold text-primary-container tracking-tight mb-4"
            >
              What I Offer
            </h2>
            <p class="text-lg font-body text-on-surface-variant">
              Practical solutions for international teams.
            </p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div
              class="bg-surface-container-lowest p-10 rounded-[1.5rem] hover:scale-[1.02] transition-transform duration-300 relative overflow-hidden group"
            >
              <div
                class="absolute top-0 right-0 w-32 h-32 bg-primary-container/5 rounded-bl-[100px] -z-10 group-hover:bg-primary-container/10 transition-colors"
              >
              </div>
              <span
                class="material-symbols-outlined text-4xl text-secondary mb-6"
                >forum</span
              >
              <h3
                class="text-xl font-headline font-bold text-primary-container mb-4"
              >
                {content.offer[0]}
              </h3>
            </div>
            <div
              class="bg-surface-container-lowest p-10 rounded-[1.5rem] hover:scale-[1.02] transition-transform duration-300 relative overflow-hidden group"
            >
              <div
                class="absolute top-0 right-0 w-32 h-32 bg-primary-container/5 rounded-bl-[100px] -z-10 group-hover:bg-primary-container/10 transition-colors"
              >
              </div>
              <span
                class="material-symbols-outlined text-4xl text-secondary mb-6"
                >handshake</span
              >
              <h3
                class="text-xl font-headline font-bold text-primary-container mb-4"
              >
                {content.offer[1]}
              </h3>
            </div>
            <div
              class="bg-surface-container-lowest p-10 rounded-[1.5rem] hover:scale-[1.02] transition-transform duration-300 relative overflow-hidden group"
            >
              <div
                class="absolute top-0 right-0 w-32 h-32 bg-primary-container/5 rounded-bl-[100px] -z-10 group-hover:bg-primary-container/10 transition-colors"
              >
              </div>
              <span
                class="material-symbols-outlined text-4xl text-secondary mb-6"
                >psychology</span
              >
              <h3
                class="text-xl font-headline font-bold text-primary-container mb-4"
              >
                {content.offer[2]}
              </h3>
            </div>
            <div
              class="bg-surface-container-lowest p-10 rounded-[1.5rem] hover:scale-[1.02] transition-transform duration-300 relative overflow-hidden group"
            >
              <div
                class="absolute top-0 right-0 w-32 h-32 bg-primary-container/5 rounded-bl-[100px] -z-10 group-hover:bg-primary-container/10 transition-colors"
              >
              </div>
              <span
                class="material-symbols-outlined text-4xl text-secondary mb-6"
                >warning</span
              >
              <h3
                class="text-xl font-headline font-bold text-primary-container mb-4"
              >
                {content.offer[3]}
              </h3>
            </div>
          </div>
        </div>
      </section>

      <section
        class="py-24 px-6 lg:px-12 bg-surface-container-low"
        id="who-this-is-for"
      >
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-16">
            <h2
              class="text-3xl lg:text-[2.75rem] font-headline font-bold text-primary-container tracking-tight mb-4"
            >
              Who This Is For
            </h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div
              class="flex items-center gap-4 p-6 bg-surface-container-lowest rounded-2xl shadow-sm"
            >
              <span class="material-symbols-outlined text-secondary text-3xl"
                >groups</span
              >
              <p
                class="text-lg font-headline font-bold text-primary-container m-0"
              >
                {content.whoFor[0]}
              </p>
            </div>
            <div
              class="flex items-center gap-4 p-6 bg-surface-container-lowest rounded-2xl shadow-sm"
            >
              <span class="material-symbols-outlined text-secondary text-3xl"
                >domain</span
              >
              <p
                class="text-lg font-headline font-bold text-primary-container m-0"
              >
                {content.whoFor[1]}
              </p>
            </div>
            <div
              class="flex items-center gap-4 p-6 bg-surface-container-lowest rounded-2xl shadow-sm"
            >
              <span class="material-symbols-outlined text-secondary text-3xl"
                >support_agent</span
              >
              <p
                class="text-lg font-headline font-bold text-primary-container m-0"
              >
                {content.whoFor[2]}
              </p>
            </div>
            <div
              class="flex items-center gap-4 p-6 bg-surface-container-lowest rounded-2xl shadow-sm"
            >
              <span class="material-symbols-outlined text-secondary text-3xl"
                >handshake</span
              >
              <p
                class="text-lg font-headline font-bold text-primary-container m-0"
              >
                {content.whoFor[3]}
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="py-24 px-6 lg:px-12 bg-surface" id="situations">
        <div class="max-w-4xl mx-auto">
          <div class="mb-16 text-center">
            <h2
              class="text-3xl lg:text-[2.75rem] font-headline font-bold text-primary-container tracking-tight mb-4"
            >
              Typical Situations
            </h2>
          </div>
          <div class="space-y-4">
            <div
              class="bg-surface-container-low p-6 rounded-2xl border border-outline-variant/30 flex items-center gap-6"
            >
              <div
                class="w-12 h-12 rounded-full bg-primary-container/10 flex items-center justify-center shrink-0"
              >
                <span class="material-symbols-outlined text-primary-container"
                  >record_voice_over</span
                >
              </div>
              <p class="text-lg font-body font-medium text-on-surface">
                {content.situations[0]}
              </p>
            </div>
            <div
              class="bg-surface-container-low p-6 rounded-2xl border border-outline-variant/30 flex items-center gap-6"
            >
              <div
                class="w-12 h-12 rounded-full bg-primary-container/10 flex items-center justify-center shrink-0"
              >
                <span class="material-symbols-outlined text-primary-container"
                  >groups</span
                >
              </div>
              <p class="text-lg font-body font-medium text-on-surface">
                {content.situations[1]}
              </p>
            </div>
            <div
              class="bg-surface-container-low p-6 rounded-2xl border border-outline-variant/30 flex items-center gap-6"
            >
              <div
                class="w-12 h-12 rounded-full bg-primary-container/10 flex items-center justify-center shrink-0"
              >
                <span class="material-symbols-outlined text-primary-container"
                  >feedback</span
                >
              </div>
              <p class="text-lg font-body font-medium text-on-surface">
                {content.situations[2]}
              </p>
            </div>
            <div
              class="bg-surface-container-low p-6 rounded-2xl border border-outline-variant/30 flex items-center gap-6"
            >
              <div
                class="w-12 h-12 rounded-full bg-primary-container/10 flex items-center justify-center shrink-0"
              >
                <span class="material-symbols-outlined text-primary-container"
                  >sync_problem</span
                >
              </div>
              <p class="text-lg font-body font-medium text-on-surface">
                {content.situations[3]}
              </p>
            </div>
          </div>
        </div>
      </section>

      <section
        class="py-24 px-6 lg:px-12 bg-surface-container-low"
        id="formats"
      >
        <div class="max-w-7xl mx-auto text-center">
          <h2
            class="text-3xl lg:text-[2.75rem] font-headline font-bold text-primary-container tracking-tight mb-12"
          >
            Workshop Formats
          </h2>
          <div class="flex flex-wrap justify-center gap-6">
            <div
              class="bg-surface-container-lowest px-8 py-6 rounded-full shadow-sm flex items-center gap-3"
            >
              <span class="material-symbols-outlined text-secondary"
                >business</span
              >
              <span
                class="text-lg font-headline font-bold text-primary-container"
                >{content.format[0]}</span
              >
            </div>
            <div
              class="bg-surface-container-lowest px-8 py-6 rounded-full shadow-sm flex items-center gap-3"
            >
              <span class="material-symbols-outlined text-secondary"
                >devices</span
              >
              <span
                class="text-lg font-headline font-bold text-primary-container"
                >{content.format[1]}</span
              >
            </div>
            <div
              class="bg-surface-container-lowest px-8 py-6 rounded-full shadow-sm flex items-center gap-3"
            >
              <span class="material-symbols-outlined text-secondary"
                >schedule</span
              >
              <span
                class="text-lg font-headline font-bold text-primary-container"
                >{content.format[2]}</span
              >
            </div>
          </div>
        </div>
      </section>

      <section
        class="py-24 px-6 lg:px-12 bg-primary-container text-on-primary"
        id="contact"
      >
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-3xl lg:text-[2.75rem] font-headline font-bold mb-6">
            Contact
          </h2>
          <p class="text-xl font-body mb-10 opacity-90">
            {content.contact.text}
          </p>
          <div class="flex flex-col items-center gap-6">
            <a
              class="text-2xl font-headline font-bold text-secondary-fixed hover:text-secondary-fixed-dim transition-colors flex items-center gap-3"
              href={`mailto:${content.contact.email}`}
            >
              <span class="material-symbols-outlined">mail</span>
              {content.contact.email}
            </a>
            <div
              class="flex items-center gap-2 text-base font-body opacity-80 mt-4"
            >
              <span class="material-symbols-outlined text-sm">location_on</span>
              <span>{content.contact.location}</span>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer
      class="bg-[#1E3932] dark:bg-[#0F1D19] w-full border-t border-white/10 text-[#FAF9F6] font-label"
    >
      <div
        class="max-w-7xl mx-auto px-12 py-16 flex flex-col md:flex-row justify-between items-center w-full"
      >
        <div class="mb-8 md:mb-0 text-center md:text-left">
          <div class="text-lg font-bold text-[#FAF9F6] mb-4">
            CultureWithGen
          </div>
          <a
            class="text-sm tracking-wide hover:text-[#E07A5F] transition-colors"
            href={`mailto:${content.contact.email}`}>{content.contact.email}</a
          >
          <p class="text-xs mt-4 text-[#FAF9F6]/60">
            {content.contact.location}
          </p>
        </div>
        <div class="flex flex-col items-center md:items-end space-y-4">
          <div
            class="flex flex-wrap justify-center md:justify-end gap-6 text-sm tracking-wide uppercase"
          >
            <a
              class="text-[#FAF9F6]/60 hover:text-[#E07A5F] transition-colors opacity-90 hover:opacity-100"
              href="/privacy">Privacy Policy</a
            >
            <a
              class="text-[#FAF9F6]/60 hover:text-[#E07A5F] transition-colors opacity-90 hover:opacity-100"
              href="/imprint">Imprint</a
            >
          </div>
          <p class="text-xs text-[#FAF9F6]/60 mt-6">
            © {new Date().getFullYear()} CultureWithGen. Elevating Global Perspectives.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
