---
import { getEntry } from "astro:content";
import { Image } from "astro:assets";

import "../styles/global.css";
import "@fontsource-variable/manrope";

import Navigation from "../components/Navigation.astro";
import ObfuscatedEmail from "../components/ObfuscatedEmail.astro";
import Seo from "../components/Seo.astro";
import StructuredData from "../components/StructuredData.astro";
import logo from "../assets/logo.webp";
import Hero from "../components/sections/Hero.astro";
import Offer from "../components/sections/Offer.astro";
import About from "../components/sections/About.astro";
import WhoFor from "../components/sections/WhoFor.astro";
import Situations from "../components/sections/Situations.astro";
import Formats from "../components/sections/Formats.astro";
import Contact from "../components/sections/Contact.astro";

const entry = await getEntry("landing", "en");
if (!entry) throw new Error("Missing landing content: src/content/landing/en.json");
const content = entry.data;

// SEO: keyword-rich title (primary service + brand) and a benefit-led,
// CTA-oriented description, both grounded in the page content. Each can be
// overridden via the CMS (content.seo); an empty/absent override falls back
// to the derived default below so nothing regresses when left blank.
const seoTitle =
  content.seo?.title?.trim() || `${content.header.eyebrow} | CultureWithGen`;
const seoDescription =
  content.seo?.description?.trim() ||
  "Practical intercultural communication workshops for international teams - in-company and online. Get in touch to improve collaboration across cultures.";
---

<html class="light" lang="en">
  <head>
    <Seo
      title={seoTitle}
      description={seoDescription}
      locale="en"
      path="/"
      alternates={{ en: "/", de: "/de/" }}
    />
    <StructuredData
      locale="en"
      path="/"
      offerItems={content.offer.items}
      description={seoDescription}
    />
  </head>

  <body
    class="bg-surface text-on-surface antialiased overflow-x-hidden font-body flex flex-col min-h-screen"
  >
    <Navigation
      homeHref="/"
      links={[
        { label: 'Services', href: '#services' },
        { label: 'About', href: '#about' },
        { label: 'Workshops', href: '#formats' },
      ]}
      ctaLabel="Let's Talk"
    />

    <main class="pt-40 flex-1">
      <Hero {...content.header} />
      <Offer {...content.offer} />
      <About {...content.about} />
      <WhoFor {...content.whoFor} />
      <Situations {...content.situations} />
      <Formats {...content.format} />
      <Contact {...content.contact} />
    </main>

    <footer class="bg-[#1E3932] w-full border-t border-white/10 text-[#FAF9F6] font-label">
      <div class="max-w-3xl mx-auto px-6 py-12 flex flex-col items-center gap-6 text-center">

        <!-- Logo -->
        <a href="/" class="hover:opacity-80 transition-opacity" aria-label="CultureWithGen home">
          <Image src={logo} alt="CultureWithGen" height={96} densities={[1, 2]} class="rounded-3xl" />
        </a>

        <!-- Tagline -->
        <p class="text-xs uppercase tracking-widest text-[#FAF9F6]/70 font-semibold">
          Intercultural Communication & Skills Training
        </p>

        <!-- Email -->
        <ObfuscatedEmail
          email={content.contact.email}
          copyOnClick
          class="text-sm text-[#FAF9F6]/80 hover:text-[#E07A5F] transition-colors tracking-wide"
        />

        <!-- Divider -->
        <div class="w-16 border-t border-white/10 mt-2"></div>

        <!-- Legal links + copyright -->
        <div class="flex flex-wrap justify-center gap-6 text-xs uppercase tracking-widest text-[#FAF9F6]/70">
          <a href="/privacy" class="hover:text-[#E07A5F] transition-colors">Privacy Policy</a>
          <a href="/imprint" class="hover:text-[#E07A5F] transition-colors">Imprint</a>
        </div>
        <p class="text-xs text-[#FAF9F6]/60">
          © {new Date().getFullYear()} CultureWithGen
        </p>

      </div>
    </footer>
  </body>
</html>
