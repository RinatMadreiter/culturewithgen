---
import { storyblokEditable } from "@storyblok/astro";

const { blok } = Astro.props;
const items = blok.items ?? [];
---

<section
  {...storyblokEditable(blok)}
  class="py-24 px-6 lg:px-12 bg-surface-container-low"
  id="formats"
>
  <div class="max-w-7xl mx-auto text-center">
    <h2
      class="text-3xl lg:text-[2.75rem] font-headline font-bold text-primary-container tracking-tight mb-12"
    >
      {blok.title}
    </h2>
    <div class="flex flex-wrap justify-center gap-6">
      {
        items.map((item) => (
          <div
            {...storyblokEditable(item)}
            class="bg-surface-container-lowest px-8 py-6 rounded-full shadow-sm flex items-center gap-3"
          >
            <span class="material-symbols-outlined text-secondary">
              {item.icon}
            </span>
            <span class="text-lg font-headline font-bold text-primary-container">
              {item.text}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>
