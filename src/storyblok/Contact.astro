---
import { storyblokEditable } from "@storyblok/astro";

const { blok } = Astro.props;
---

<section
  {...storyblokEditable(blok)}
  class="py-24 px-6 lg:px-12 bg-primary-container text-on-primary"
  id="contact"
>
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-3xl lg:text-[2.75rem] font-headline font-bold mb-6">
      {blok.title}
    </h2>
    <p class="text-xl font-body mb-10 opacity-90">
      {blok.text}
    </p>
    <div class="flex flex-col items-center gap-6">
      <a
        class="text-2xl font-headline font-bold text-secondary-fixed hover:text-secondary-fixed-dim transition-colors flex items-center gap-3"
        href={`mailto:${blok.email}`}
      >
        <span class="material-symbols-outlined">mail</span>
        {blok.email}
      </a>
      <div class="flex items-center gap-2 text-base font-body opacity-80 mt-4">
        <span class="material-symbols-outlined text-sm">location_on</span>
        <span>{blok.location}</span>
      </div>
    </div>
  </div>
</section>
