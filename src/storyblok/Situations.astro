---
import { storyblokEditable } from "@storyblok/astro";

const { blok } = Astro.props;
const items = blok.items ?? [];
---

<section
  {...storyblokEditable(blok)}
  class="py-24 px-6 lg:px-12 bg-surface"
  id="situations"
>
  <div class="max-w-4xl mx-auto">
    <div class="mb-16 text-center">
      <h2
        class="text-3xl lg:text-[2.75rem] font-headline font-bold text-primary-container tracking-tight mb-4"
      >
        {blok.title}
      </h2>
    </div>
    <div class="space-y-4">
      {
        items.map((item) => (
          <div
            {...storyblokEditable(item)}
            class="bg-surface-container-low p-6 rounded-2xl border border-outline-variant/30 flex items-center gap-6"
          >
            <div class="w-12 h-12 rounded-full bg-primary-container/10 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-primary-container">
                {item.icon}
              </span>
            </div>
            <p class="text-lg font-body font-medium text-on-surface">
              {item.text}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
