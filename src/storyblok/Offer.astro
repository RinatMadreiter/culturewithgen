---
import { storyblokEditable } from "@storyblok/astro";

const { blok } = Astro.props;
const items = blok.items ?? [];
---

<section
  {...storyblokEditable(blok)}
  class="py-24 px-6 lg:px-12 bg-surface"
  id="services"
>
  <div class="max-w-7xl mx-auto">
    <div class="mb-16">
      <h2
        class="text-3xl lg:text-[2.75rem] font-headline font-bold text-primary-container tracking-tight mb-4"
      >
        {blok.title}
      </h2>
      {
        blok.subtitle && (
          <p class="text-lg font-body text-on-surface-variant">
            {blok.subtitle}
          </p>
        )
      }
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        items.map((item) => (
          <div
            {...storyblokEditable(item)}
            class="bg-surface-container-lowest p-10 rounded-[1.5rem] hover:scale-[1.02] transition-transform duration-300 relative overflow-hidden group"
          >
            <div class="absolute top-0 right-0 w-32 h-32 bg-primary-container/5 rounded-bl-[100px] -z-10 group-hover:bg-primary-container/10 transition-colors" />
            <span class="material-symbols-outlined text-4xl text-secondary mb-6">
              {item.icon}
            </span>
            <h3 class="text-xl font-headline font-bold text-primary-container mb-4">
              {item.text}
            </h3>
          </div>
        ))
      }
    </div>
  </div>
</section>
