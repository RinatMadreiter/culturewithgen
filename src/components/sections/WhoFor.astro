---
import Icon from "../Icon.astro";

interface Item {
  icon: string;
  text: string;
}

interface Props {
  title: string;
  items: Item[];
}

const { title, items = [] } = Astro.props;
---

<section
  class="py-12 lg:py-24 px-6 lg:px-12 bg-surface-container-low"
  id="who-this-is-for"
>
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2
        class="text-3xl lg:text-[2.75rem] font-headline font-bold text-primary-container tracking-tight mb-4"
      >
        {title}
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        items.map((item) => (
          <div class="flex items-center gap-4 p-6 bg-[#F4F7F5] border border-[#1E3932]/20 rounded-2xl shadow-sm hover:scale-[1.02] hover:shadow-md transition-all duration-300 relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-32 h-32 bg-[#1E3932]/5 rounded-bl-[100px] -z-10 group-hover:bg-[#1E3932]/10 transition-colors" />
            <Icon name={item.icon} class="text-[#9A442D] text-3xl" />
            <p class="text-lg font-headline font-bold text-[#1E3932] m-0">
              {item.text}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
