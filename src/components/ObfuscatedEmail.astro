---
// Spam-resistant email link. The address is encoded into ONE opaque token
// (no plaintext, no user/domain split) and only decoded on real user intent,
// so DOM-snapshot scrapers never see it. A readable "[at] / [dot]" fallback
// shows if JS is off; humans get a normal clickable mailto link on interaction.
interface Props {
  email: string;
  class?: string;
  iconClass?: string;
  showIcon?: boolean;
}

const { email, class: className = "", iconClass = "", showIcon = false } =
  Astro.props;

// Build-time encode: XOR each char with a rolling key, then base64. The static
// HTML carries only the opaque token, never the address or its parts.
const KEY = 0x2a;
const encode = (s: string) =>
  Buffer.from(
    Array.from(s)
      .map((c, i) => String.fromCharCode(c.charCodeAt(0) ^ (KEY + (i % 7))))
      .join(""),
    "binary",
  ).toString("base64");

const token = encode(email);
const [user = "", domain = ""] = email.split("@");
const fallback = `${user} [at] ${domain.replace(/\./g, " [dot] ")}`;
---

<a
  class:list={["js-email", className]}
  href="#"
  data-cfe={token}
  rel="nofollow noopener"
  aria-label="Reveal email address"
>
  {
    showIcon && (
      <span class:list={["material-symbols-outlined", iconClass]} aria-hidden="true">
        mail
      </span>
    )
  }
  <span class="js-email-text">{fallback}</span>
</a>

<script>
  // Mirror of the build-time encoder. Reverses XOR-rolling-key + base64.
  const KEY = 0x2a;
  const decode = (token: string) => {
    const bin = atob(token);
    let out = "";
    for (let i = 0; i < bin.length; i++)
      out += String.fromCharCode(bin.charCodeAt(i) ^ (KEY + (i % 7)));
    return out;
  };

  document.querySelectorAll<HTMLAnchorElement>("a.js-email").forEach((a) => {
    const token = a.dataset.cfe;
    if (!token) return;
    let done = false;
    const reveal = () => {
      if (done) return;
      done = true;
      const address = decode(token);
      a.href = `mailto:${address}`;
      const label = a.querySelector(".js-email-text");
      if (label) label.textContent = address;
    };
    // Decode only on genuine user intent. pointerdown, focus, touchstart and
    // contextmenu all fire before navigation/copy, so the first click, keyboard
    // activation or right-click still lands on the real address. A scraper that
    // only snapshots the DOM never triggers any of these.
    ["pointerdown", "focus", "touchstart", "contextmenu"].forEach((evt) =>
      a.addEventListener(evt, reveal),
    );
  });
</script>
