---
import "../styles/global.css";
import { Image } from "astro:assets";
import Icon from "./Icon.astro";
import logo from "../assets/logo.webp";

interface NavLink {
  label: string;
  href: string;
}

interface Props {
  homeHref: string;
  links: NavLink[];
  ctaLabel: string;
}

const { homeHref, links, ctaLabel } = Astro.props;
---

<nav
  class="fixed top-0 w-full z-50 bg-surface backdrop-blur-md shadow-md font-label tracking-tight text-on-surface"
>
  <div
    class="flex justify-between items-center px-4 md:px-8 py-4 max-w-7xl mx-auto"
  >
    <a
      href={homeHref}
      class="text-xl rounded-xl font-bold transition-transform hover:scale-105 shrink-0"
    >
      <Image
        alt="CultureWithGen Logo"
        class="h-20 rounded-3xl md:h-36 w-auto object-contain"
        src={logo}
        height={144}
        densities={[1, 2]}
        loading="eager"
      />
      <span class="sr-only">CultureWithGen</span>
    </a>

    <div class="hidden md:flex items-center space-x-8">
      {
        links.map((item) => (
          <a
            class="hover:text-primary hover:underline transition-all duration-200"
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
    </div>

    <div class="flex items-center space-x-4 md:space-x-6 shrink-0">
      <!-- Language switcher: inline from md up. On small screens it lives in
           the menu below, so the bar stays within narrow viewports even with
           long translated CTA labels. -->
      <div class="hidden md:flex text-sm font-semibold tracking-wider gap-2">
        <a
          href="/"
          class="js-lang-en hover:text-primary hover:underline transition-all duration-200"
          >EN</a
        >
        <span class="text-outline">|</span>
        <a
          href="/de/"
          class="js-lang-de hover:text-primary hover:underline transition-all duration-200"
          >DE</a
        >
      </div>

      <a
        href="#contact"
        class="bg-[#9A442D] text-white px-4 py-2 md:px-6 rounded-lg font-bold shadow-[0_6px_20px_rgba(154,68,45,0.35)] hover:bg-[#7D3522] hover:shadow-[0_8px_24px_rgba(154,68,45,0.45)] hover:-translate-y-0.5 transition-all duration-200"
      >
        {ctaLabel}
      </a>

      <!-- Mobile-only section menu: native <details> disclosure, no JS library.
           The panel anchors to the fixed <nav> (its positioning context). -->
      <details id="mobile-nav" class="mobile-nav md:hidden">
        <summary
          class="flex items-center justify-center cursor-pointer text-2xl text-on-surface hover:text-primary transition-colors"
          aria-label="Open menu"
        >
          <Icon name="menu" />
        </summary>
        <div
          class="absolute left-0 right-0 top-full bg-white shadow-md border-t border-[#1E3932]/10 flex flex-col py-2 font-label"
        >
          {
            links.map((item) => (
              <a
                class="px-6 py-3 hover:text-primary hover:bg-[#F4F7F5] transition-colors"
                href={item.href}
              >
                {item.label}
              </a>
            ))
          }
          <div
            class="mt-2 flex border-t border-[#1E3932]/10 pt-2 text-sm font-semibold tracking-wider"
          >
            <a
              href="/"
              class="js-lang-en flex-1 px-6 py-3 hover:text-primary hover:bg-[#F4F7F5] transition-colors"
              >EN</a
            >
            <a
              href="/de/"
              class="js-lang-de flex-1 px-6 py-3 hover:text-primary hover:bg-[#F4F7F5] transition-colors"
              >DE</a
            >
          </div>
        </div>
      </details>
    </div>
  </div>
</nav>

<style>
  /* Remove the default disclosure triangle so the hamburger stands alone. */
  .mobile-nav > summary {
    list-style: none;
  }
  .mobile-nav > summary::-webkit-details-marker {
    display: none;
  }
</style>

<script>
  // Track the currently visible section and keep language links pointing to it.
  // Selected by class, not id: the switcher renders twice (inline on desktop,
  // inside the menu on mobile), so both copies must stay in sync.
  function setLangHref(hash: string) {
    document
      .querySelectorAll<HTMLAnchorElement>("a.js-lang-en")
      .forEach((a) => (a.href = "/" + hash));
    document
      .querySelectorAll<HTMLAnchorElement>("a.js-lang-de")
      .forEach((a) => (a.href = "/de/" + hash));
  }

  function getActiveSection(): string {
    const sections = Array.from(
      document.querySelectorAll<HTMLElement>("section[id]"),
    );
    const navH = 96; // fixed nav height offset
    const viewTop = navH;
    const viewBottom = window.innerHeight;
    let active = "";
    let maxVisible = 0;
    for (const s of sections) {
      const rect = s.getBoundingClientRect();
      // Height of this section currently visible below the nav
      const visible =
        Math.min(rect.bottom, viewBottom) - Math.max(rect.top, viewTop);
      if (visible > maxVisible) {
        maxVisible = visible;
        active = s.id;
      }
    }
    return active ? "#" + active : "";
  }

  function sync() {
    const hash = getActiveSection();
    if (hash) setLangHref(hash);
  }

  // Seed on load from URL hash first, then correct via scroll position
  setLangHref(window.location.hash);
  sync();

  window.addEventListener("scroll", sync, { passive: true });
  window.addEventListener("hashchange", () =>
    setLangHref(window.location.hash),
  );

  // Mobile menu: collapse the <details> after picking a link, and when
  // tapping/clicking outside it. Keyboard toggling is handled natively.
  const mobileNav = document.getElementById(
    "mobile-nav",
  ) as HTMLDetailsElement | null;
  if (mobileNav) {
    mobileNav.querySelectorAll("a").forEach((link) =>
      link.addEventListener("click", () => {
        mobileNav.open = false;
      }),
    );
    document.addEventListener("click", (e) => {
      if (mobileNav.open && !mobileNav.contains(e.target as Node)) {
        mobileNav.open = false;
      }
    });
  }
</script>
