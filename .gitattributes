# Normalize all text files to LF in the repo and working tree.
# Matches Prettier's default (endOfLine: "lf") so Git, the editor, and
# `pnpm format` all agree, and silences the CRLF conversion warnings on Windows.
* text=auto eol=lf

# Binary assets: never apply text/EOL conversion.
*.webp binary
*.png binary
*.jpg binary
*.jpeg binary
*.avif binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
